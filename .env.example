# --- Redis (must match the Continuum API's REDIS_URL) ---
REDIS_URL=redis://localhost:6379/0

# --- Continuum API ---
# Public URL of the Continuum API (no trailing slash)
BACKEND_URL=http://localhost:8001
# Shared secret used to HMAC-sign requests to /api/v1/internal/agent/...
# Must match AGENT_RUNNER_HMAC_SECRET on the API side.
AGENT_RUNNER_HMAC_SECRET=change-me

# --- LLM (mirrors the API's LiteLLM settings) ---
LLM_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1
LLM_EXPLORE_MODEL=gpt-4.1-mini
LLM_SYNTHESIZE_MODEL=gpt-4.1
LLM_SYNTHESIZE_TOOLS=write_file,apply_patch,commit_and_push,done

# --- GitHub App (so the runner can mint installation access tokens locally
#     without round-tripping the API every time) ---
GITHUB_APP_ID=
# Paste the full PEM. Newlines may be literal "\n" — the runner normalizes them.
GITHUB_APP_PRIVATE_KEY=

# --- Runner tuning ---
RUNNER_CONCURRENCY=2
# Keep above MAX_WALL_CLOCK_SECONDS (in ms): a job is only ack'd after it
# finishes, so a run still going past this idle window gets re-executed by
# another worker.
JOB_STALE_IDLE_MS=15000000
WORKSPACE_ROOT=/work
LOG_LEVEL=INFO

# --- Hard guardrails (override defaults if you need to) ---
# Wall-clock ceiling per run. Generous so large tasks can finish; only reaps
# genuinely stuck runs. If you raise it, raise JOB_STALE_IDLE_MS to stay above.
MAX_WALL_CLOCK_SECONDS=14400
# Enforced: a run is reaped once its cumulative input+output tokens exceed
# (MAX_TOKENS_PER_RUN - TOKEN_BUDGET_HEADROOM). Generous so large tasks finish;
# lower it if you want a tighter spend ceiling.
MAX_TOKENS_PER_RUN=2000000
# Reserved margin below the cap. Tokens are reported only after each turn, so
# the kill fires early enough that one more turn can't blow past the real cap.
TOKEN_BUDGET_HEADROOM=200000
MAX_SHELL_OUTPUT_BYTES=64000
HISTORY_COMPACT_TOKEN_THRESHOLD=60000
HISTORY_KEEP_RECENT_TOOL_RESULTS=4
